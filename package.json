{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -- turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "dotenv -- pnpm -F db push",
    "db:studio": "pnpm -F db studio"
  },
  "devDependencies": {
    "@types/node": "^20.9.4",
    "dotenv-cli": "latest",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "tsconfig": "workspace:*",
    "turbo": "latest"
  },
  "packageManager": "pnpm@8.6.10",
  "name": "fullstack-turbo-next-trpc"
}
